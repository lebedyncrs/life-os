# PostgreSQL (see docker-compose.yml at repo root)
DATABASE_URL=postgresql://lifeos:lifeos@localhost:5432/lifeos

# Session cookie signing (min 32 chars)
SESSION_SECRET=change-me-32chars-minimum----------

# Telegram Bot API
TELEGRAM_BOT_TOKEN=123456:ABC-from-BotFather
# Must match the secret segment in your webhook URL .../telegram/webhook/<secret>
TELEGRAM_WEBHOOK_SECRET=random-long-secret-for-url
# Optional: ngrok (or prod) HTTPS origin only — no path, no query (see quickstart §7)
# TELEGRAM_WEBHOOK_URL=https://xxxx.ngrok-free.app
# Optional (dev): numeric chat id — on boot, links to the first Owner (skip /start)
# TELEGRAM_CHAT_ID=123456789

# Dashboard SPA origin (CORS + cookies)
WEB_ORIGIN=http://localhost:5173

# NLU + voice (OpenAI-compatible). Required for shopping capture from text/voice.
NLU_PROVIDER_BASE_URL=https://api.openai.com/v1
NLU_PROVIDER_API_KEY=
NLU_CHAT_MODEL=gpt-4o-mini

# Server
PORT=3000
NODE_ENV=development

# Optional: used by `pnpm run seed:owner` when no CLI args (same as bootstrap:owner)
# OWNER_BOOTSTRAP_EMAIL=you@example.com
# OWNER_BOOTSTRAP_PASSWORD=change-me-8chars-min
# OWNER_BOOTSTRAP_TELEGRAM_LINK_TOKEN=
